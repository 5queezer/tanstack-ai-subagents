{
  "name": "@5queezer/tanstack-ai-subagents",
  "version": "0.1.0",
  "description": "Unofficial reusable subagent routing and execution helpers for TanStack AI applications.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "demo",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "tanstack",
    "ai",
    "agents",
    "subagents",
    "orchestration"
  ],
  "author": "5queezer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/5queezer/tanstack-ai-subagents.git"
  },
  "bugs": {
    "url": "https://github.com/5queezer/tanstack-ai-subagents/issues"
  },
  "homepage": "https://github.com/5queezer/tanstack-ai-subagents#readme",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@tanstack/ai": "^0.14.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tanstack/ai": "^0.14.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
